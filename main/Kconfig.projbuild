menu "Example Configuration"

    config STORE_HISTORY
        bool "Store command history in flash"
        default y
        help
            Linenoise line editing library provides functions to save and load
            command history. If this option is enabled, initalizes a FAT filesystem
            and uses it to store command history.

endmenu

menu "Bridge Configuration"

    config ETH_MDC_GPIO
        int "ETH MDC GPIO"
        default 23

    config ETH_MDIO_GPIO
        int "ETH MDIO GPIO"
        default 18

    config ETH_PHY_ADDR
        int "ETH PHY address"
        default 1

    config ETH_PHY_POWER_GPIO
        int "ETH PHY power GPIO (-1 for none)"
        default 16

    config BRIDGE_FDB_MAX_ENTRIES
        int "Bridge FDB max dynamic entries"
        default 48
        range 4 256
        help
            Maximum number of dynamic entries in the bridge forwarding
            database (MAC address table). Each entry tracks a learned
            MAC address and its associated port. Increase if the bridge
            serves many devices.

endmenu
